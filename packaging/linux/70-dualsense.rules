# udev rules for Sony DualSense and DualSense Edge (PS5) controllers.
#
# Linux restricts HID device access to root by default. These rules grant
# read/write permission to the logged-in user so HorizonHaptics can write
# adaptive trigger effects without requiring sudo.
#
# Covers both USB and Bluetooth connections for:
#   DualSense      (USB product ID 0CE6)
#   DualSense Edge (USB product ID 0DF2)
#
# Vendor/product IDs sourced from the public USB ID database (usb.ids).
#
# Install:
#   sudo cp 70-dualsense.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
#
# Then unplug and replug (USB) or re-pair (Bluetooth) the controller.

# DualSense - hidraw interface (USB)
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0660", TAG+="uaccess"

# DualSense - USB subsystem
SUBSYSTEM=="usb", ATTR{idVendor}=="054c", ATTR{idProduct}=="0ce6", MODE="0660", TAG+="uaccess"

# DualSense Edge - hidraw interface (USB)
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0df2", MODE="0660", TAG+="uaccess"

# DualSense Edge - USB subsystem
SUBSYSTEM=="usb", ATTR{idVendor}=="054c", ATTR{idProduct}=="0df2", MODE="0660", TAG+="uaccess"

# DualSense - Bluetooth
KERNELS=="0005:054C:0CE6.*", MODE="0660", TAG+="uaccess"

# DualSense Edge - Bluetooth
KERNELS=="0005:054C:0DF2.*", MODE="0660", TAG+="uaccess"
