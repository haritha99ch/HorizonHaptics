# udev rules for Sony DualSense and DualSense Edge (PS5) controllers.
# Allows non-root users to read/write the HID device, required for adaptive
# trigger feedback over both USB and Bluetooth.
#
# Install:
#   sudo cp 70-dualsense.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger
# Then unplug/replug (USB) or re-pair (Bluetooth) the controller.

# DualSense (0CE6) - USB
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="054c", ATTR{idProduct}=="0ce6", MODE="0660", TAG+="uaccess"

# DualSense Edge (0DF2) - USB
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0df2", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="usb", ATTR{idVendor}=="054c", ATTR{idProduct}=="0df2", MODE="0660", TAG+="uaccess"

# DualSense - Bluetooth
KERNELS=="0005:054C:0CE6.*", MODE="0660", TAG+="uaccess"

# DualSense Edge - Bluetooth
KERNELS=="0005:054C:0DF2.*", MODE="0660", TAG+="uaccess"
